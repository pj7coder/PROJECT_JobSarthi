{
  "crons": [
    {
      "path": "/api/cron-collect",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/cron-collect",
      "dest": "/api/cron-collect.js"
    },
    {
      "src": "/api/send-email",
      "dest": "/api/send-email.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://project-jobsarthi.onrender.com/api/$1"
    }
  ]
}
